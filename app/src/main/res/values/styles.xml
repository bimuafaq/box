<resources>
    <style name="Widget.Custom.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="android:layout_margin">16dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Material3.SmallComponent</item>
    </style>

    <!-- Navigation Label Styles -->
    <style name="TextAppearance.App.NavigationLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Floating Action Button Style - No Shadow -->
    <style name="Widget.App.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="elevation">0dp</item>
        <item name="pressedTranslationZ">0dp</item>
        <item name="hoveredFocusedTranslationZ">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.App.FloatingActionButton.Mini" parent="Widget.App.FloatingActionButton">
        <item name="fabSize">mini</item>
    </style>

    <!-- Light Theme Material 3 - Warm Amber -->
    <style name="Theme.OXController" parent="Theme.Material3.Light.NoActionBar">
        <!-- Window background - warm off-white -->
        <item name="android:windowBackground">#FFFBF8</item>
        <item name="colorSurface">#FFFBF8</item>
        <!-- Transparent Status Bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Transparent Navigation Bar -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="snackbarStyle">@style/Widget.Custom.Snackbar</item>
        <item name="floatingActionButtonStyle">@style/Widget.App.FloatingActionButton</item>
        <!-- Warm Amber Palette -->
        <item name="colorPrimary">#8B5000</item>
        <item name="colorPrimaryContainer">#FFDCBE</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorOnPrimaryContainer">#2C1500</item>
        <item name="colorSecondary">#745A42</item>
        <item name="colorSecondaryContainer">#FFDCC0</item>
        <item name="colorOnSecondary">#3B2815</item>
        <item name="colorOnSecondaryContainer">#56412D</item>
        <item name="colorTertiary">#5B623A</item>
        <item name="colorTertiaryContainer">#DFE6B4</item>
        <item name="colorOnTertiary">#1A1E03</item>
        <item name="colorOnTertiaryContainer">#3A411B</item>
        <item name="colorError">#BA1A1A</item>
        <item name="colorErrorContainer">#F9DEDC</item>
        <item name="colorOnError">#FFFFFF</item>
        <item name="colorOnErrorContainer">#410E0B</item>
        <item name="colorSurfaceContainer">#F5E9DD</item>
        <item name="colorSurfaceContainerHigh">#F0E0D1</item>
        <item name="colorSurfaceContainerHighest">#EBD7C5</item>
        <item name="colorSurfaceVariant">#F0E0D1</item>
        <item name="colorOnSurface">#1E1B16</item>
        <item name="colorOnSurfaceVariant">#4F4539</item>
    </style>
</resources>
