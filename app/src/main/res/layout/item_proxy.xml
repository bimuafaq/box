<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/proxyCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:strokeWidth="1dp"
    app:strokeColor="@android:color/transparent"
    android:clickable="true"
    android:focusable="true"
    style="?attr/materialCardViewFilledStyle">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/proxyName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_proxy_name_label"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:ellipsize="end"
            android:maxLines="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/proxyType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/placeholder_proxy_type"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:alpha="0.7"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/proxyLatency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_latency"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
