<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/proxyCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:strokeWidth="1dp"
    app:strokeColor="@android:color/transparent"
    android:clickable="true"
    android:focusable="true"
    style="?attr/materialCardViewFilledStyle">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/proxyName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Proxy Name"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/proxyLatency"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/proxyType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shadowsocks"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_below="@id/proxyName"
            android:layout_marginTop="2dp"
            android:alpha="0.7" />

        <TextView
            android:id="@+id/proxyLatency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="---"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
