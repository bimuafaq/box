<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- DASHBOARD TOOLBAR (Outside Card) -->
    <LinearLayout
        android:id="@+id/webHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:visibility="gone">
        
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseWeb"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:icon="@drawable/ic_back_arrow"
            app:iconSize="24dp"
            app:iconTint="?attr/colorOnSurface" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/label_web_interface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginStart="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRefreshWeb"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:icon="@drawable/ic_refresh"
            app:iconSize="22dp"
            app:iconTint="?attr/colorOnSurface" />
    </LinearLayout>

    <!-- INITIAL TITLE -->
    <LinearLayout
        android:id="@+id/dashHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        
        <TextView
            android:id="@+id/dashTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_dashboard"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:paddingTop="32dp"
            android:paddingBottom="12dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

        <!-- OPEN PANEL BUTTON (NOW IN HEADER) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenFullWeb"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:icon="@drawable/ic_dashboard"
            app:iconSize="22dp"
            app:iconTint="?attr/colorOnSurface" />
    </LinearLayout>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/initialLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="4dp"
                android:paddingBottom="80dp">

                <!-- MODUL 1: STATUS & SYSTEM INFO (COMPACT MD3 FILLED CARD) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer"
                    app:strokeWidth="0dp"
                    style="?attr/materialCardViewFilledStyle">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <!-- HEADER INFO -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            
                            <!-- LEFT: ACTIVE CORE -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_active_core"
                                    android:textSize="12sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:textAllCaps="true"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.05" />
                                <TextView
                                    android:id="@+id/coreText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/placeholder_latency"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurface" />
                            </LinearLayout>

                            <!-- RIGHT: STATUS CARD -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/statusCard"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp"
                                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">
                                <TextView
                                    android:id="@+id/statusText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/status_ready"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="6dp"
                                    android:textColor="?attr/colorPrimary" />
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="12dp"
                            android:layout_marginBottom="12dp"
                            android:background="?attr/colorOutlineVariant"
                            android:alpha="0.5" />

                        <!-- GRID STATS (CPU and RAM closer, UPTIME at end) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_cpu" android:textSize="12sp" android:textStyle="bold" android:textColor="?attr/colorOnSurfaceVariant" />
                                <TextView android:id="@+id/cpuText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/value_empty_percent" android:textSize="14sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                            </LinearLayout>

                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="32dp" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_ram" android:textSize="12sp" android:textStyle="bold" android:textColor="?attr/colorOnSurfaceVariant" />
                                <TextView android:id="@+id/ramText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/value_empty_mb" android:textSize="14sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
                            </LinearLayout>

                            <Space
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="end" android:orientation="vertical">
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- STATS GRID (Connections - Upload - Download sejajar) -->
                <LinearLayout
                    android:id="@+id/clashStatsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="16dp">

                    <!-- CONNECTIONS -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardConnections"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="?attr/colorSurfaceContainer"
                        app:strokeWidth="0dp"
                        style="?attr/materialCardViewFilledStyle">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_active"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:alpha="0.6" />

                            <TextView
                                android:id="@+id/clashConnectionsText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/value_zero"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- UPLOAD -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="?attr/colorSurfaceContainer"
                        app:strokeWidth="0dp"
                        style="?attr/materialCardViewFilledStyle">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_upload"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:alpha="0.6" />

                            <TextView
                                android:id="@+id/clashUploadText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/value_zero_bytes"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- DOWNLOAD -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="?attr/colorSurfaceContainer"
                        app:strokeWidth="0dp"
                        style="?attr/materialCardViewFilledStyle">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_download"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:alpha="0.6" />

                            <TextView
                                android:id="@+id/clashDownloadText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/value_zero_bytes"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- PROXY GROUPS SECTION -->
                <LinearLayout
                    android:id="@+id/proxyGroupsHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/labelProxyGroups"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_proxy_groups"
                        android:textSize="12sp"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLatencyDash"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/desc_test_latency"
                        app:icon="@drawable/ic_bolt"
                        app:iconSize="20dp"
                        app:iconTint="?attr/colorPrimary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/proxyGroupsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- FAB (SERVICE) -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/btnService"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="24dp"
            app:icon="@drawable/ic_play_arrow"
            app:iconTint="?attr/colorOnPrimaryContainer"
            app:backgroundTint="?attr/colorPrimaryContainer" />

        <!-- WEBVIEW CONTAINER (OVERLAY) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/webViewContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurface"
            app:strokeWidth="0dp"
            app:cardCornerRadius="0dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <WebView
                    android:id="@+id/dashWebView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</LinearLayout>
