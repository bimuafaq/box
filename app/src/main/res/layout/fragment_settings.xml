<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?attr/android:windowBackground">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_settings"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:paddingStart="4dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- APPEARANCE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cat_appearance"
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingStart="8dp"
                android:paddingBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                style="?attr/materialCardViewFilledStyle">
                
                <LinearLayout
                    android:id="@+id/themeSelection"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_app_theme"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface" />
                    <TextView
                        android:id="@+id/currentThemeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_system_default"
                        android:textSize="13sp"
                        android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- DASHBOARD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DASHBOARD"
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingStart="8dp"
                android:paddingBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                style="?attr/materialCardViewFilledStyle">
                
                <LinearLayout
                    android:id="@+id/dashUrlSelection"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dashboard URL"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface" />
                    <TextView
                        android:id="@+id/currentDashUrlText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="http://127.0.0.1:9090/ui"
                        android:textSize="13sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:singleLine="true"
                        android:ellipsize="end" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
