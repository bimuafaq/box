<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?attr/android:windowBackground">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_home"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingStart="4dp" />

    <!-- MODUL 1: STATUS & SYSTEM INFO -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:contentPadding="20dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <!-- ROW 1: STATUS (Left) & CORE (Right) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="start"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_service_status"
                        android:textSize="10sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:layout_gravity="start" />
                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_ready"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_indigo"
                        android:layout_marginTop="2dp"
                        android:layout_gravity="start" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVE CORE"
                        android:textSize="10sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:layout_gravity="end" />
                    <TextView
                        android:id="@+id/coreText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="---"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginTop="2dp"
                        android:layout_gravity="end"
                        android:gravity="end" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="#1A000000" />

            <!-- ROW 2: CPU, RAM, CORE (Left), UPTIME (Right) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CPU"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorSecondary" />
                    <TextView
                        android:id="@+id/cpuText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginTop="1dp" />
                </LinearLayout>
                <View android:layout_width="24dp" android:layout_height="0dp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RAM"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorSecondary" />
                    <TextView
                        android:id="@+id/ramText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 MB"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginTop="1dp" />
                </LinearLayout>
                <View android:layout_width="24dp" android:layout_height="0dp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CORE"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorSecondary" />
                    <TextView
                        android:id="@+id/idCoreText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginTop="1dp" />
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPTIME"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_gravity="end" />
                    <TextView
                        android:id="@+id/runtimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00:00"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginTop="1dp"
                        android:layout_gravity="end"
                        android:gravity="end" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- MODUL 2: COMPACT CONTROLS (No Card) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:weightSum="3">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/startBtn"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="START"
            android:layout_marginEnd="4dp"
            app:backgroundTint="@color/primary_indigo"
            app:cornerRadius="16dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/restartBtn"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="RESTART"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            app:backgroundTint="#FFB300"
            app:cornerRadius="16dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/stopBtn"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="STOP"
            android:layout_marginStart="4dp"
            app:backgroundTint="#E53935"
            app:cornerRadius="16dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>

    <!-- MODUL 3: DASHBOARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:contentPadding="20dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_dashboard"
                android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:paddingBottom="16dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/webBtn"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_open_dashboard"
                app:cornerRadius="16dp"
                android:textColor="@color/primary_indigo"
                app:strokeColor="@color/primary_indigo" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
