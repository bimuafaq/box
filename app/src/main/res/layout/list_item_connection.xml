<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:strokeWidth="0dp"
    style="?attr/materialCardViewFilledStyle">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/connNetwork"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_network_type"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnTertiaryContainer"
                    android:background="?attr/colorTertiaryContainer"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="2dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/connHost"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_connection_host"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:ellipsize="middle"
                    android:maxLines="1"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <TextView
                android:id="@+id/connMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_connection_meta"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="4dp"
                android:alpha="0.8"
                android:textIsSelectable="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/connProxy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/placeholder_proxy_name"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary" />

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_arrow_up_material"
                android:contentDescription="@string/label_upload"
                app:tint="?attr/colorOnSurfaceVariant"
                android:alpha="0.5" />
            <TextView
                android:id="@+id/connUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/value_zero_bytes"
                android:textSize="12sp"
                android:layout_marginStart="2dp"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_arrow_down_material"
                android:contentDescription="@string/label_download"
                app:tint="?attr/colorOnSurfaceVariant"
                android:layout_marginStart="8dp"
                android:alpha="0.5" />
            <TextView
                android:id="@+id/connDown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/value_zero_bytes"
                android:textSize="12sp"
                android:layout_marginStart="2dp"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
