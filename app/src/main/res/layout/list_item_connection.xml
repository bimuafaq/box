<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:strokeWidth="0dp"
    style="?attr/materialCardViewFilledStyle">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/connHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="example.com"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:ellipsize="middle"
            android:maxLines="1" />

        <TextView
            android:id="@+id/connMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HTTPS • 192.168.1.1"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="2dp"
            android:alpha="0.7" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/connProxy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ProxyName"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary" />

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_arrow_up_material"
                app:tint="?attr/colorOnSurfaceVariant"
                android:alpha="0.5" />
            <TextView
                android:id="@+id/connUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 B"
                android:textSize="10sp"
                android:layout_marginStart="2dp"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_arrow_down_material"
                app:tint="?attr/colorOnSurfaceVariant"
                android:layout_marginStart="8dp"
                android:alpha="0.5" />
            <TextView
                android:id="@+id/connDown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 B"
                android:textSize="10sp"
                android:layout_marginStart="2dp"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
